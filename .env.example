# Database Analyzer - Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration (required)
DB_SERVER=your_database_server
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# Qwen LLM Configuration (optional - defaults shown)
# QWEN_MODEL=qwen-max
# QWEN_MODEL_SERVER=http://localhost:5001/api/v1
# QWEN_API_KEY=EMPTY

# Claude LLM Configuration (optional - for Claude backend)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# CLAUDE_MODEL=claude-opus-4-5
# CLAUDE_MAX_TOKENS=16000
# CLAUDE_EXTENDED_THINKING=true
# CLAUDE_THINKING_BUDGET=10000
